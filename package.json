{
  "name": "ai-command-center",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:web dev:api dev:bridge",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "npm --workspace apps/api run dev",
    "dev:bridge": "npm --workspace services/agent-bridge run dev",
    "dev:jobs": "npm --workspace services/jobs run dev",
    "build": "npm run build:web && npm run build:api && npm run build:bridge && npm run build:jobs",
    "build:web": "npm --workspace apps/web run build",
    "build:api": "npm --workspace apps/api run build",
    "build:bridge": "npm --workspace services/agent-bridge run build",
    "build:jobs": "npm --workspace services/jobs run build",
    "start:web": "npm --workspace apps/web run start",
    "start:api": "npm --workspace apps/api run start",
    "start:bridge": "npm --workspace services/agent-bridge run start",
    "start:jobs": "npm --workspace services/jobs run start",
    "lint": "npm --workspace apps/web run lint"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
